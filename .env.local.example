# Copy this file to .env.local and fill in values from Supabase (Project Settings → API).

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Server-only: never commit .env.local. Used so the dashboard can read all rows for this internal demo.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Anyone who knows this string can open the dashboard (no login). Use a long random value for demos.
DASHBOARD_SECRET=change-me-to-a-long-random-secret

# Optional: used by the home page demo buttons to build links. If set, use the same value as DASHBOARD_SECRET.
# NEXT_PUBLIC_DASHBOARD_SECRET=change-me-to-a-long-random-secret
